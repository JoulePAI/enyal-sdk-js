{
  "name": "@enyalai/sdk",
  "version": "2.1.0",
  "description": "ENYAL SDK — encrypted knowledge graph, local memory, permanent proof",
  "type": "module",
  "main": "./dist/index.cjs",
  "exports": {
    ".": {
      "import": "./index.js",
      "require": "./dist/index.cjs"
    },
    "./enyal-client.js": {
      "import": "./enyal-client.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "index.js",
    "enyal-client.js",
    "enyal_agent.js",
    "local_knowledge.js",
    "dist/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18.7.0"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0"
  },
  "scripts": {
    "build": "esbuild index.js --bundle --platform=node --format=cjs --outfile=dist/index.cjs --external:better-sqlite3",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "enyal",
    "knowledge-graph",
    "zero-knowledge",
    "archival",
    "sdk"
  ],
  "license": "Apache-2.0",
  "author": "Greenland AI Limited <info@enyal.ai>",
  "homepage": "https://enyal.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/JoulePAI/enyal-sdk-js.git"
  },
  "devDependencies": {
    "esbuild": "^0.28.0"
  }
}
